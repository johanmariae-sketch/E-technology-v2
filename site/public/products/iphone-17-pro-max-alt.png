<script type="rocketlazyloadscript">
document.addEventListener('DOMContentLoaded', function() {
  const carousels = document.querySelectorAll('.carousel-container');

  carousels.forEach(function(carouselContainer) {
    const carousel = carouselContainer.querySelector('.carousel');
    const leftBtn = carouselContainer.querySelector('.left-btn');
    const rightBtn = carouselContainer.querySelector('.right-btn');

    function updateButtonVisibility() {
      if (carousel.scrollLeft === 0) {
        leftBtn.style.display = 'none'; // Hide left button
      } else {
        leftBtn.style.display = 'flex'; // Show left button
      }

      if (carousel.scrollLeft + carousel.offsetWidth >= carousel.scrollWidth) {
        rightBtn.style.display = 'none'; // Hide right button
      } else {
        rightBtn.style.display = 'flex'; // Show right button
      }
    }

    function scrollCarousel(direction) {
      const scrollAmount = 150; // Adjust scroll amount as needed
      carousel.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    }

    updateButtonVisibility();

    carousel.addEventListener('scroll', updateButtonVisibility);

    leftBtn.addEventListener('click', () => scrollCarousel(-1)); // Scroll left
    rightBtn.addEventListener('click', () => scrollCarousel(1)); // Scroll right
  });
});
</script>
